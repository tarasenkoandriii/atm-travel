# БД / расписание
DATABASE_URL=postgresql://...
DIRECT_URL=postgresql://...
REFRESH_CRON=0 15 * * *          # для постоянного процесса (@nestjs/schedule)
REFRESH_TZ=Europe/Kyiv
# На Vercel Hobby расписание задаётся в vercel.json (crons), ТОЛЬКО UTC, напр. "0 12 * * *"
CRON_SECRET=change-me            # защита /api/cron/refresh (Vercel Authorization Bearer)
SNAPSHOT_STORE=postgres          # postgres | blob

# Liveness
LIVENESS_CONCURRENCY=8
LIVENESS_TIMEOUT_MS=8000
DEAD_THRESHOLD=5

# Камеры
WINDY_API_KEY=
WINDY_TARGET=1000
YOUTUBE_API_KEY=             # если пусто — источник YouTube НЕ используется (сид пропускается, YT-камеры скрываются)

# Погода (WeatherAPI.com — free, 3 дня)
WEATHERAPI_KEY=
WEATHER_FORECAST_DAYS=3
WEATHER_TTL_SEC=7200
WEATHER_UNITS=metric

# Путешествия (Travelpayouts — Viator/GetYourGuide)
# Без этих ключей сайт работает и показывает РАБОЧИЕ обычные ссылки брендов (нужно для ревью).
# Как заполнятся token+marker+trs и программы подключены — ссылки на лету станут партнёрскими.
TRAVELPAYOUTS_TOKEN=          # Profile → API token (X-Access-Token)
TRAVELPAYOUTS_MARKER=         # affiliate marker (ваш partner ID)
TRAVELPAYOUTS_TRS=            # ID проекта, подписанного на программы (из списка проектов)
TRAVEL_PRIMARY_BRANDS=viator,getyourguide
TRAVEL_DEFAULT_CURRENCY=USD
TRAVEL_LINK_TTL_SEC=2592000   # кеш партнёрских ссылок (~30 дней)

# i18n
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,uk,ru,pl,fr,de,ja,it,pt,es

# Безопасность
ADMIN_API_KEY=change-me
ALLOWED_ORIGINS=http://localhost:3000,https://atm-travel.org,https://t.me
PORT=3000

# Горящие туры (Viator Deals feed). URL выдаёт support Travelpayouts по запросу.
# Пусто — витрина скрыта (никаких выдуманных скидок).
VIATOR_DEALS_FEED_URL=
DEALS_MIN_DISCOUNT=10          # минимальная скидка (%), чтобы попасть в витрину
DEALS_LIMIT=12                # сколько карточек держать

# eSIM (Airalo Partner API). Credentials from partners.airalo.com. Empty => eSIM disabled.
ESIM_PROVIDER=airalo
ESIM_MARKUP_PCT=20             # your retail markup over provider price, %
AIRALO_CLIENT_ID=
AIRALO_CLIENT_SECRET=
AIRALO_BASE_URL=https://partners-api.airalo.com
AIRALO_API_VERSION=v2
ESIM_CHECKOUT_URL=           # optional: where the "Buy" chip links (checkout page). Empty => teaser only.

# eSIM checkout — WayForPay (wiki.wayforpay.com). Empty => checkout disabled.
WFP_MERCHANT_ACCOUNT=
WFP_MERCHANT_DOMAIN=          # e.g. atm-travel.org (must match WayForPay merchant settings)
WFP_SECRET_KEY=
WFP_CURRENCY=USD             # charge currency; if UAH set ESIM_FX_RATE accordingly
ESIM_FX_RATE=1               # multiply package price (USD) -> WFP_CURRENCY
PUBLIC_BASE_URL=             # e.g. https://atm-travel.org — used for return/callback URLs
GOOGLE_CLIENT_ID=            # optional: enables Google sign-in on checkout

# Cinematic route -> Vercel Blob (auto-set when a Blob store is connected in Vercel). Empty => local download.
BLOB_READ_WRITE_TOKEN=

# Auto-source B-roll for /reel (optional; set one). Pexels preferred if both present.
PEXELS_API_KEY=
PIXABAY_API_KEY=
XAI_API_KEY=
