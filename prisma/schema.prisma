// ATM-travel.org — Prisma schema (ТЗ §4)
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Camera {
  id            String       @id @default(cuid())
  source        CameraSource
  externalId    String
  type          CameraType
  provider      String?
  title         String
  city          String?
  country       String?
  cc            String?
  lat           Float
  lng           Float
  tz            String       @default("UTC")
  res           String       @default("HD")
  videoId       String?
  embed         String?
  clipUrl       String?
  img           String?
  category      String?
  wcCategory    String?
  iata          String?
  isLive        Boolean      @default(false)
  viewerCount   Int?
  lastCheckedAt DateTime?
  lastLiveAt    DateTime?
  failCount     Int          @default(0)
  sortOrder     Int          @default(0)
  status        CameraStatus @default(ACTIVE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([source, externalId])
  @@index([status, isLive, category])
}

model RefreshRun {
  id           String         @id @default(cuid())
  trigger      RefreshTrigger
  startedAt    DateTime       @default(now())
  finishedAt   DateTime?
  durationMs   Int?
  totalChecked Int            @default(0)
  liveCount    Int            @default(0)
  deadCount    Int            @default(0)
  addedCount   Int            @default(0)
  windyStatus  Int?
  error        String?
}

model WeatherCache {
  gridKey   String   @id
  payload   Json
  days      Int
  fetchedAt DateTime @default(now())

  @@index([fetchedAt])
}

model TravelOfferCache {
  key       String   @id
  payload   Json
  fetchedAt DateTime @default(now())

  @@index([fetchedAt])
}

model Snapshot {
  id      String   @id @default("catalog")
  payload Json
  builtAt DateTime @default(now())
}

enum CameraSource {
  YOUTUBE
  WINDY
}

enum CameraType {
  YOUTUBE
  IFRAME
  IMAGE
}

enum CameraStatus {
  ACTIVE
  HIDDEN
  DEAD
}

enum RefreshTrigger {
  CRON
  MANUAL
  WEBHOOK
}

model EsimSale {
  id               String    @id @default(cuid())
  orderReference   String    @unique
  provider         String    @default("airalo")
  packageId        String
  country          String
  email            String?
  amountMinor      Int
  currency         String
  status           String    @default("pending") // pending | paid | provisioned | failed
  iccid            String?
  qrCode           String?   @db.Text
  qrCodeUrl        String?   @db.Text
  appleInstallUrl  String?   @db.Text
  instructionsHtml String?   @db.Text
  createdAt        DateTime  @default(now())
  paidAt           DateTime?
  provisionedAt    DateTime?

  @@index([status])
}

model CineRender {
  id          String   @id @default(cuid())
  lat         Float
  lng         Float
  durationSec Int      @default(7)
  title       String?
  items       Json
  createdAt   DateTime @default(now())
}

// Short-lived clip selection passed from /cine to /reels by id (avoids long ?clips URLs).
model ClipSet {
  id        String   @id @default(cuid())
  items     Json
  createdAt DateTime @default(now())
}
