{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    { "path": "/api/cron/refresh", "schedule": "0 12 * * *" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 300,
      "includeFiles": "public/**"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ]
}
